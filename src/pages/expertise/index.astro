---
import { getEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageContent = await getEntry('pages', 'expertise');
if (!pageContent) throw new Error("Unable to locate expertise.md in content layer.");
const { Content } = await render(pageContent);

const capabilities = (await getCollection('expertise'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={pageContent.data.title} description={pageContent.data.description}>
  <!-- Page Header -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 pt-24 pb-20 grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-7">
        <div class="flex items-center gap-3 mb-6">
          <span class="rule-oxblood"></span>
          <span class="eyebrow-oxblood">§ What we do</span>
        </div>
        <h1 class="display text-5xl md:text-7xl leading-[0.98]">
          {pageContent.data.title}
        </h1>
      </div>
      <div class="md:col-span-5 md:pt-4">
        <div class="prose prose-neutral max-w-none text-ink-soft text-[1.0625rem] leading-relaxed font-serif">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Capability Cards -->
  <section class="max-w-6xl mx-auto px-6">
    {capabilities.map((cap) => (
      <a
        href={`/expertise/${cap.id}`}
        class="group block border-b border-rule py-14 grid grid-cols-1 md:grid-cols-12 gap-8 hover:bg-paper-warm transition-colors -mx-6 px-6"
      >
        <!-- Index -->
        <div class="md:col-span-1 pt-1">
          <span class="index-number text-6xl">{cap.data.capIndex}</span>
        </div>

        <!-- Title + Summary -->
        <div class="md:col-span-7">
          <h2 class="font-serif text-2xl md:text-3xl leading-snug mb-4 group-hover:text-oxblood transition-colors">
            {cap.data.title}
          </h2>
          <p class="text-[15px] text-ink-soft leading-relaxed max-w-xl font-serif">{cap.data.summary}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {cap.data.tags.map((tag) => (
              <span class="stack-chip">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Arrow CTA -->
        <div class="md:col-span-4 flex md:items-start md:justify-end pt-1">
          <span class="eyebrow group-hover:text-oxblood transition-colors inline-flex items-center gap-2">
            View capability
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </span>
        </div>
      </a>
    ))}
  </section>
</BaseLayout>
