---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const contactContent = await getEntry('pages', 'contact');
if (!contactContent) {
  throw new Error("Unable to locate contact.md in content layer.");
}
const { Content } = await render(contactContent);

const CONTACT_EMAIL = 'eduardo.hernandez@tecnofin.com';
---

<BaseLayout title={contactContent.data.title} description={contactContent.data.description}>
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-24 grid grid-cols-1 md:grid-cols-12 gap-16 items-start">
    <!-- Context Panel -->
    <div class="md:col-span-5">
      <div class="flex items-center gap-3 mb-6">
        <span class="rule-oxblood"></span>
        <span class="eyebrow-oxblood">§ Connect</span>
      </div>
      <h1 class="display text-5xl md:text-6xl leading-[0.98] mb-8">
        {contactContent.data.title}
      </h1>
      <div class="prose prose-neutral text-ink-soft text-[1.0625rem] leading-relaxed font-serif mb-10">
        <Content />
      </div>

      <a href={`mailto:${CONTACT_EMAIL}`} class="btn-oxblood mb-10">
        Email an architect
        <span aria-hidden="true">→</span>
      </a>

      <div class="border-t border-rule pt-6 flex flex-col gap-4">
        <div>
          <p class="eyebrow mb-2">Response window</p>
          <p class="font-serif text-base text-ink leading-snug">All messages reviewed directly by an engineering partner. Reply within one business day.</p>
        </div>
        <div>
          <p class="eyebrow mb-2">Direct</p>
          <a href={`mailto:${CONTACT_EMAIL}`} class="font-mono text-sm text-oxblood hover:underline">{CONTACT_EMAIL}</a>
        </div>
      </div>
    </div>

    <!-- Two-Week Build — source-to-value data graph -->
    <div class="md:col-span-7">
      <figure class="bv-panel depth-bloom bg-paper-warm border border-rule p-8 md:p-10 overflow-hidden">
        <figcaption class="flex items-center justify-between border-b border-rule pb-5 mb-7">
          <span class="eyebrow-oxblood">Two-Week Build — Source to Value</span>
          <span class="font-mono text-[11px] text-muted">Day 1 → Day 14</span>
        </figcaption>

        <svg
          class="bv-svg w-full h-auto"
          viewBox="0 0 560 600"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-label="A two-week build timeline: scattered source data — customer, market, operations — assembling into a structured, owned data graph that resolves into fast, trusted, AI-ready value."
        >
          <defs>
            <pattern id="bv-grid" width="28" height="28" patternUnits="userSpaceOnUse">
              <path d="M 28 0 L 0 0 0 28" fill="none" stroke="var(--color-rule)" stroke-width="0.6" opacity="0.5" />
            </pattern>
            <filter id="bv-glow" x="-60%" y="-60%" width="220%" height="220%">
              <feGaussianBlur stdDeviation="4" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
            <radialGradient id="bv-value-fill" cx="50%" cy="40%" r="70%">
              <stop offset="0%" stop-color="var(--color-oxblood-soft)" />
              <stop offset="100%" stop-color="var(--color-oxblood-deep)" />
            </radialGradient>
          </defs>

          <rect x="0" y="0" width="560" height="600" fill="url(#bv-grid)" />

          <!-- ===== Timeline axis (left) ===== -->
          <g font-family="var(--font-mono)" font-size="9" letter-spacing="1.5">
            <line x1="74" y1="92" x2="74" y2="536" stroke="var(--color-rule-soft)" stroke-width="1.5" />
            <!-- animated momentum overlay -->
            <line class="bv-axis" x1="74" y1="92" x2="74" y2="536" stroke="var(--color-oxblood)" stroke-width="1.5" stroke-dasharray="6 10" stroke-linecap="round" />
            <g fill="var(--color-muted)">
              <line x1="68" y1="108" x2="80" y2="108" stroke="var(--color-rule-soft)" stroke-width="1" />
              <text x="10" y="111">DAY 01</text>
              <line x1="68" y1="314" x2="80" y2="314" stroke="var(--color-rule-soft)" stroke-width="1" />
              <text x="10" y="317">DAY 07</text>
              <line x1="68" y1="520" x2="80" y2="520" stroke="var(--color-rule-soft)" stroke-width="1" />
              <text x="10" y="523">DAY 14</text>
            </g>
          </g>

          <!-- ===== Edges ===== -->
          <!-- hub → satellite constellation (the build) -->
          <g stroke="var(--color-rule-soft)" stroke-width="1">
            <line x1="330" y1="300" x2="330" y2="246" />
            <line x1="330" y1="300" x2="384" y2="273" />
            <line x1="330" y1="300" x2="384" y2="327" />
            <line x1="330" y1="300" x2="330" y2="354" />
            <line x1="330" y1="300" x2="276" y2="327" />
            <line x1="330" y1="300" x2="276" y2="273" />
          </g>

          <!-- sources → hub (animated) -->
          <g class="bv-flow" stroke="var(--color-oxblood)" stroke-width="1.5" stroke-dasharray="5 9" stroke-linecap="round">
            <path d="M 200 138 C 230 200, 300 240, 320 278" />
            <path d="M 352 126 C 352 190, 338 250, 332 278" />
            <path d="M 488 152 C 470 210, 390 250, 344 286" />
          </g>

          <!-- hub → value (animated) -->
          <g class="bv-flow bv-flow--late" stroke="var(--color-oxblood)" stroke-width="1.5" stroke-dasharray="5 9" stroke-linecap="round">
            <path d="M 320 322 C 280 370, 210 400, 196 442" />
            <path d="M 330 322 C 330 380, 330 410, 330 466" />
            <path d="M 344 322 C 384 370, 454 400, 468 442" />
          </g>

          <!-- ===== Source nodes (Day 1–3) ===== -->
          <g font-family="var(--font-mono)">
            <g transform="translate(152, 108)">
              <rect width="104" height="30" rx="5" fill="var(--color-paper-deep)" stroke="var(--color-rule-soft)" />
              <text x="9" y="13" font-size="7.5" letter-spacing="1.5" fill="var(--color-muted)">SRC</text>
              <text x="9" y="24" font-size="10" fill="var(--color-ink-soft)">customer</text>
            </g>
            <g transform="translate(300, 96)">
              <rect width="104" height="30" rx="5" fill="var(--color-paper-deep)" stroke="var(--color-rule-soft)" />
              <text x="9" y="13" font-size="7.5" letter-spacing="1.5" fill="var(--color-muted)">SRC</text>
              <text x="9" y="24" font-size="10" fill="var(--color-ink-soft)">market</text>
            </g>
            <g transform="translate(436, 122)">
              <rect width="104" height="30" rx="5" fill="var(--color-paper-deep)" stroke="var(--color-rule-soft)" />
              <text x="9" y="13" font-size="7.5" letter-spacing="1.5" fill="var(--color-muted)">SRC</text>
              <text x="9" y="24" font-size="10" fill="var(--color-ink-soft)">operations</text>
            </g>
          </g>

          <!-- ===== The build — hub + constellation (Day 4–10) ===== -->
          <g class="bv-sat" fill="var(--color-paper-warm)" stroke="var(--color-oxblood-deep)" stroke-width="1.25">
            <circle cx="330" cy="246" r="4.5" />
            <circle cx="384" cy="273" r="4.5" />
            <circle cx="384" cy="327" r="4.5" />
            <circle cx="330" cy="354" r="4.5" />
            <circle cx="276" cy="327" r="4.5" />
            <circle cx="276" cy="273" r="4.5" />
          </g>
          <g class="bv-hub" filter="url(#bv-glow)">
            <rect x="286" y="278" width="88" height="44" rx="9" fill="url(#bv-value-fill)" stroke="var(--color-oxblood-soft)" stroke-width="1.5" />
            <text x="330" y="298" text-anchor="middle" font-family="var(--font-mono)" font-size="8" letter-spacing="1.5" fill="var(--color-paper)">YOUR DATA</text>
            <text x="330" y="311" text-anchor="middle" font-family="var(--font-mono)" font-size="10" font-weight="500" fill="var(--color-paper)">graph</text>
          </g>

          <!-- ===== Value outputs (Day 11–14) ===== -->
          <g class="bv-value" font-family="var(--font-mono)" filter="url(#bv-glow)">
            <g transform="translate(148, 442)">
              <rect width="96" height="34" rx="6" fill="var(--color-paper-deep)" stroke="var(--color-oxblood)" stroke-width="1.5" />
              <text x="48" y="21" text-anchor="middle" font-size="10" fill="var(--color-oxblood-soft)">AI-READY</text>
            </g>
            <g transform="translate(282, 466)" class="bv-value--delay">
              <rect width="96" height="34" rx="6" fill="var(--color-paper-deep)" stroke="var(--color-oxblood)" stroke-width="1.5" />
              <text x="48" y="21" text-anchor="middle" font-size="10" fill="var(--color-oxblood-soft)">TRUSTED</text>
            </g>
            <g transform="translate(420, 442)" class="bv-value--delay2">
              <rect width="96" height="34" rx="6" fill="var(--color-paper-deep)" stroke="var(--color-oxblood)" stroke-width="1.5" />
              <text x="48" y="21" text-anchor="middle" font-size="10" fill="var(--color-oxblood-soft)">OWNED</text>
            </g>
          </g>

          <!-- legend strip -->
          <g font-family="var(--font-mono)" font-size="7.5" fill="var(--color-muted)" letter-spacing="1.2">
            <text x="120" y="566">SOURCES — DATA ONLY YOU HAVE</text>
            <text x="120" y="578">BUILD — STRUCTURED, TESTED, OWNED  ·  VALUE — FAST, TRUSTED, AI-READY</text>
          </g>
        </svg>

        <!-- Legend -->
        <div class="mt-7 pt-5 border-t border-rule flex flex-wrap gap-x-7 gap-y-3 font-mono text-[11px] text-muted">
          <span class="flex items-center gap-2"><span class="bv-key bv-key--src"></span>Sources — your unique data</span>
          <span class="flex items-center gap-2"><span class="bv-key bv-key--hub"></span>The build — owned in two weeks</span>
          <span class="flex items-center gap-2"><span class="bv-key bv-key--value"></span>Value — fast, trusted, AI-ready</span>
        </div>
      </figure>
    </div>
  </section>
</BaseLayout>

<style>
  .bv-panel { position: relative; }
  .bv-svg { display: block; }

  /* Flowing dataflow along the source→hub and hub→value edges */
  .bv-flow path { animation: bv-dash 1.5s linear infinite; }
  .bv-flow--late path { animation-duration: 1.9s; }
  @keyframes bv-dash { to { stroke-dashoffset: -28; } }

  /* Momentum running down the timeline axis */
  .bv-axis { animation: bv-axis-dash 2.4s linear infinite; }
  @keyframes bv-axis-dash { to { stroke-dashoffset: -32; } }

  /* Breathing glow on the central graph */
  .bv-hub {
    transform-box: fill-box;
    transform-origin: center;
    animation: bv-pulse 3.6s ease-in-out infinite;
  }
  @keyframes bv-pulse {
    0%, 100% { opacity: 0.92; }
    50%      { opacity: 1; }
  }

  /* Value nodes resolve in, staggered */
  .bv-value g { animation: bv-value-in 4.2s ease-in-out infinite; }
  .bv-value--delay { animation-delay: 0.5s; }
  .bv-value--delay2 { animation-delay: 1s; }
  @keyframes bv-value-in {
    0%, 100% { opacity: 0.8; }
    50%      { opacity: 1; }
  }

  /* Legend keys */
  .bv-key {
    width: 11px;
    height: 11px;
    display: inline-block;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .bv-key--src {
    background: var(--color-paper-deep);
    border: 1px solid var(--color-rule-soft);
  }
  .bv-key--hub {
    background: var(--color-oxblood);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-oxblood) 22%, transparent);
  }
  .bv-key--value {
    background: var(--color-paper-deep);
    border: 1.5px solid var(--color-oxblood);
  }

  @media (prefers-reduced-motion: reduce) {
    .bv-flow path,
    .bv-flow--late path,
    .bv-axis,
    .bv-hub,
    .bv-value g {
      animation: none;
    }
  }
</style>
