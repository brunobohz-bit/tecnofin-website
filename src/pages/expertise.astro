---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const expertiseContent = await getEntry('pages', 'expertise');
if (!expertiseContent) {
  throw new Error("Unable to locate expertise.md in content layer.");
}
const { Content } = await render(expertiseContent);
---

<BaseLayout title={expertiseContent.data.title} description={expertiseContent.data.description}>
  <!-- Header Block -->
  <section class="border-b border-border-subtle py-16 bg-cream">
    <div class="max-w-6xl mx-auto px-6">
      <span class="text-xs uppercase tracking-widest font-semibold text-muted-gray">Our Specializations</span>
      <h1 class="text-3xl md:text-5xl font-serif mt-4 max-w-3xl leading-tight">
        {expertiseContent.data.title}
      </h1>
    </div>
  </section>

  <!-- Split Navigation/Content Layout -->
  <section class="max-w-6xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-12 gap-12">
    <!-- Sticky Sidebar Navigation -->
    <aside class="md:col-span-4">
      <div class="sticky top-24 border-r border-border-subtle pr-8 flex flex-col gap-4 text-sm font-medium text-muted-gray">
        <span class="text-xs uppercase tracking-widest text-ink font-bold border-b border-border-subtle pb-2">Technical Index</span>
        <a href="#warehousing" class="hover:text-ink transition-colors">Data Warehousing</a>
        <a href="#vault" class="hover:text-ink transition-colors">Data Vault Engineering</a>
        <a href="#governance" class="hover:text-ink transition-colors">Data Governance</a>
      </div>
    </aside>

    <!-- Main Core Content -->
    <div class="md:col-span-8 prose prose-neutral max-w-none prose-headings:font-serif prose-headings:font-medium prose-h2:text-2xl prose-h2:border-b prose-h2:border-border-subtle prose-h2:pb-2 text-muted-gray">
      <Content />
    </div>
  </section>
</BaseLayout>
