---
import { getEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const pageContent = await getEntry('pages', 'success-cases');
if (!pageContent) {
  throw new Error("Unable to locate success-cases.md in content layer.");
}
const { Content } = await render(pageContent);

const cases = (await getCollection('successCases'))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={pageContent.data.title} description={pageContent.data.description}>
  <!-- Page Header -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 pt-24 pb-20">
      <div class="flex items-center gap-3 mb-6">
        <span class="rule-oxblood"></span>
        <span class="eyebrow-oxblood">§ Our track record</span>
      </div>
      <h1 class="display text-5xl md:text-7xl max-w-4xl leading-[0.98]">
        {pageContent.data.title}
      </h1>
      <div class="mt-10 prose prose-neutral max-w-2xl text-ink-soft text-[1.25rem] leading-relaxed font-serif">
        <Content />
      </div>
    </div>
  </section>

  <!-- Case Cards -->
  <section class="max-w-6xl mx-auto px-6">
    {cases.map((c) => (
      <article class="reveal border-b border-rule py-16 grid grid-cols-1 md:grid-cols-12 gap-10">
        <!-- Index + Meta -->
        <div class="md:col-span-3">
          <span class="index-number text-4xl">{c.data.index}</span>
          <p class="eyebrow mt-6">{c.data.industry}</p>
          <p class="mt-2 font-serif text-lg text-ink leading-snug">{c.data.client}</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {c.data.tags.map((tag) => (
              <span class="stack-chip">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Before -->
        <div class="md:col-span-4">
          <p class="eyebrow mb-4">Before</p>
          <p class="text-[17px] text-muted leading-relaxed font-serif">{c.data.challenge}</p>
        </div>

        <!-- Outcome metric + business result -->
        <div class="md:col-span-5 md:border-l md:border-rule md:pl-10">
          <p class="eyebrow-oxblood mb-4">Outcome</p>
          <div class="display text-6xl md:text-7xl text-oxblood leading-none">{c.data.metric}</div>
          <p class="mt-2 text-[11px] uppercase tracking-widest font-mono text-muted">{c.data.metricLabel}</p>
          <p class="eyebrow mt-8 mb-3">Business result</p>
          <p class="font-serif text-lg text-ink leading-snug">{c.data.result}</p>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
