---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const contactContent = await getEntry('pages', 'contact');
if (!contactContent) {
  throw new Error("Unable to locate contact.md in content layer.");
}
const { Content } = await render(contactContent);
---

<BaseLayout title={contactContent.data.title} description={contactContent.data.description}>
  <section class="max-w-6xl mx-auto px-6 pt-24 pb-24 grid grid-cols-1 md:grid-cols-12 gap-16">
    <!-- Context Panel -->
    <div class="md:col-span-5">
      <div class="flex items-center gap-3 mb-6">
        <span class="rule-oxblood"></span>
        <span class="eyebrow-oxblood">§ Connect</span>
      </div>
      <h1 class="display text-5xl md:text-6xl leading-[0.98] mb-8">
        {contactContent.data.title}
      </h1>
      <div class="prose prose-neutral text-ink-soft text-[1.0625rem] leading-relaxed font-serif mb-10">
        <Content />
      </div>

      <div class="border-t border-rule pt-6 flex flex-col gap-4">
        <div>
          <p class="eyebrow mb-2">Response window</p>
          <p class="font-serif text-base text-ink leading-snug">All messages reviewed directly by an engineering partner. Reply within one business day.</p>
        </div>
        <div>
          <p class="eyebrow mb-2">Direct</p>
          <a href="mailto:hello@tecnofin.io" class="font-mono text-sm text-oxblood hover:underline">hello@tecnofin.io</a>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="md:col-span-7">
      <!-- TODO: Replace YOUR_FORM_ID with your Formspree form ID -->
      <form action="https://formspree.io/f/YOUR_FORM_ID" method="POST" class="flex flex-col gap-7 bg-paper-warm border border-rule p-8 md:p-12">
        <div class="flex items-center justify-between border-b border-rule pb-5 mb-2">
          <span class="eyebrow-oxblood">Engagement intake — Form 01</span>
          <span class="font-mono text-[11px] text-muted">3 fields · 90 sec</span>
        </div>

        <div>
          <label for="name" class="eyebrow block mb-2">01 · Contact name</label>
          <input type="text" id="name" name="name" required
            class="w-full bg-transparent border-0 border-b border-rule px-0 py-3 text-base font-serif focus:outline-none focus:border-oxblood transition-colors" />
        </div>

        <div>
          <label for="email" class="eyebrow block mb-2">02 · Work email</label>
          <input type="email" id="email" name="email" required
            class="w-full bg-transparent border-0 border-b border-rule px-0 py-3 text-base font-serif focus:outline-none focus:border-oxblood transition-colors" />
        </div>

        <div>
          <label for="message" class="eyebrow block mb-2">03 · Scope of work / infrastructure hurdles</label>
          <textarea id="message" name="message" rows="5" required
            class="w-full bg-transparent border-0 border-b border-rule px-0 py-3 text-base font-serif focus:outline-none focus:border-oxblood transition-colors resize-none"></textarea>
        </div>

        <!-- Honeypot field — hidden from humans, catches bots that fill all fields -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <button type="submit" class="btn-oxblood self-start mt-2">
          Submit for review
          <span aria-hidden="true">→</span>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
