---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-6xl mx-auto px-6 pt-32 pb-40">
    <div class="flex items-center gap-3 mb-8">
      <span class="rule-oxblood"></span>
      <span class="eyebrow-oxblood">§ 404</span>
    </div>
    <h1 class="display text-5xl md:text-7xl leading-[0.98] mb-8">
      Page not found.
    </h1>
    <p class="text-[1.25rem] text-ink-soft font-serif leading-relaxed max-w-lg mb-10">
      The page you're looking for doesn't exist or has been moved. Head back to the homepage or browse our capabilities.
    </p>
    <div class="flex flex-wrap items-center gap-4">
      <a href="/" class="btn-oxblood">
        Return home
        <span aria-hidden="true">→</span>
      </a>
      <a href="/expertise" class="btn-ghost">
        Browse expertise
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</BaseLayout>
