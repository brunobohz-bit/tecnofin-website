---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { METRICS, SECTIONS } from '../config/site';

const homeContent = await getEntry('pages', 'home');
if (!homeContent) {
  throw new Error("Unable to locate home.md in content layer.");
}
---

<BaseLayout title={homeContent.data.title} description={homeContent.data.description}>
  <!-- HERO -->
  <section class="relative overflow-hidden border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 pt-24 md:pt-32 pb-20 md:pb-28 grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <!-- Headline column -->
      <div class="lg:col-span-7">
        <div class="flex items-center gap-3 mb-8">
          <span class="rule-oxblood"></span>
          <span class="eyebrow-oxblood">Enterprise Data Infrastructure · Est. 2018</span>
        </div>
        <h1 class="display text-[2.75rem] sm:text-6xl lg:text-[5.25rem] text-ink leading-[0.98] tracking-tight">
          We build <em class="italic text-oxblood">bulletproof</em> pipeline infrastructure for data teams that can't afford to break.
        </h1>
        <p class="mt-10 max-w-xl text-[1.0625rem] leading-relaxed text-ink-soft font-serif">
          {homeContent.data.description}
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="/contact" class="btn-oxblood">
            Start a two-week build
            <span aria-hidden="true">→</span>
          </a>
          <a href="/expertise" class="btn-ghost">
            See what we do
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>

      <!-- Signature visual: stylized lineage graph -->
      <div class="lg:col-span-5 relative">
        <div class="absolute inset-0 -z-0 paper-grain opacity-50 rounded-sm"></div>
        <svg viewBox="0 0 420 360" class="relative w-full h-auto" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
              <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#2E2922" stroke-width="0.5" opacity="0.55"/>
            </pattern>
          </defs>
          <rect width="420" height="360" fill="url(#grid)" />

          <!-- Edges: sources → vault → marts -->
          <g fill="none" stroke="#D4A84B" stroke-width="1.25" opacity="0.75">
            <path d="M 60 60 C 150 60, 150 180, 220 180" />
            <path d="M 60 130 C 150 130, 150 180, 220 180" />
            <path d="M 60 200 C 150 200, 150 180, 220 180" />
            <path d="M 60 270 C 150 270, 150 180, 220 180" />
            <path d="M 280 180 C 330 180, 330 90, 380 90" />
            <path d="M 280 180 C 330 180, 330 180, 380 180" />
            <path d="M 280 180 C 330 180, 330 270, 380 270" />
          </g>

          <!-- Source nodes (left column) -->
          <g font-family="JetBrains Mono, monospace" font-size="9" fill="#F5EFE3">
            <g>
              <rect x="20" y="48" width="80" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="60" y="63" text-anchor="middle">SOURCE_01</text>
            </g>
            <g>
              <rect x="20" y="118" width="80" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="60" y="133" text-anchor="middle">SOURCE_02</text>
            </g>
            <g>
              <rect x="20" y="188" width="80" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="60" y="203" text-anchor="middle">SOURCE_03</text>
            </g>
            <g>
              <rect x="20" y="258" width="80" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="60" y="273" text-anchor="middle">SOURCE_04</text>
            </g>
          </g>

          <!-- Vault hub (center) -->
          <g>
            <rect x="220" y="160" width="60" height="40" fill="#D4A84B" stroke="#B08830" stroke-width="0.75"/>
            <text x="250" y="178" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#0D0B09">DATA</text>
            <text x="250" y="190" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#0D0B09">VAULT</text>
          </g>

          <!-- Output marts (right column) -->
          <g font-family="JetBrains Mono, monospace" font-size="9" fill="#F5EFE3">
            <g>
              <rect x="340" y="78" width="70" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="375" y="93" text-anchor="middle">MART · BI</text>
            </g>
            <g>
              <rect x="340" y="168" width="70" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="375" y="183" text-anchor="middle">MART · ML</text>
            </g>
            <g>
              <rect x="340" y="258" width="70" height="24" fill="#1E1A16" stroke="#F5EFE3" stroke-width="0.75"/>
              <text x="375" y="273" text-anchor="middle">MART · OPS</text>
            </g>
          </g>

          <!-- Legend strip -->
          <g font-family="JetBrains Mono, monospace" font-size="7" fill="#8A7A6A" letter-spacing="1.2">
            <text x="20" y="335">FIG. 01 — REFERENCE PIPELINE ARCHITECTURE</text>
            <text x="20" y="348">SOURCES → RAW VAULT → BUSINESS MARTS</text>
          </g>
        </svg>
      </div>
    </div>

    <!-- Metric strip -->
    <div class="border-t border-rule bg-paper-deep/30">
      <div class="max-w-6xl mx-auto px-6 grid grid-cols-2 md:grid-cols-4 divide-x divide-rule">
        {METRICS.map((m) => (
          <div class="px-6 py-8 first:pl-0 md:px-8 md:py-10">
            <div class="display text-4xl md:text-5xl text-oxblood leading-none">{m.value}</div>
            <p class="mt-3 text-[12px] uppercase tracking-widest font-mono text-muted leading-snug">{m.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SECTION INDEX — the five-section hub -->
  <section class="max-w-6xl mx-auto px-6 py-24">
    <div class="max-w-3xl mb-12">
      <span class="eyebrow-oxblood">§ Where to start</span>
      <h2 class="display text-3xl md:text-5xl mt-4 leading-[1.05]">
        Five ways in.
      </h2>
    </div>
    <div class="border-t border-rule">
      {SECTIONS.map((s) => (
        <a
          href={s.href}
          class="group block border-b border-rule py-8 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-baseline hover:bg-paper-warm transition-colors -mx-6 px-6"
        >
          <div class="md:col-span-1">
            <span class="index-number text-2xl">{s.index}</span>
          </div>
          <div class="md:col-span-4">
            <h3 class="font-serif text-2xl md:text-3xl leading-snug group-hover:text-oxblood transition-colors">
              {s.label}
            </h3>
          </div>
          <div class="md:col-span-6">
            <p class="text-[15px] text-ink-soft leading-relaxed font-serif">{s.teaser}</p>
          </div>
          <div class="md:col-span-1 flex md:justify-end">
            <span aria-hidden="true" class="text-muted group-hover:text-oxblood transition-all group-hover:translate-x-1 text-xl">→</span>
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
