---
import { getCollection } from 'astro:content';
import { SITE_URL } from '../config/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, SITE_URL).toString();
const ogImageURL = ogImage ?? `${SITE_URL}/og-default.png`;
const pageTitle = `${title} | Tecnofin`;

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};

const nav = [
  { href: '/value', label: 'Business Value' },
  { href: '/expertise', label: 'Expertise' },
  { href: '/dna', label: 'How We Work' },
  { href: '/success-cases', label: 'Success Cases' },
  { href: '/contact', label: 'Contact' },
];

const expertiseLinks = (await getCollection('expertise'))
  .sort((a, b) => a.data.order - b.data.order)
  .map((e) => ({ href: `/expertise/${e.id}`, label: e.data.title }));
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>

    <!-- Open Graph / Twitter Card -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Structured data (inert JSON-LD, not executable JS) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Tecnofin",
      "url": SITE_URL,
      "logo": `${SITE_URL}/logo.png`,
      "image": `${SITE_URL}/og-default.png`,
      "description": "Enterprise data engineering — pipeline infrastructure, Data Vault 2.0 modeling, and automated governance that turn a company's unique data into a fast, trusted, AI-ready foundation it owns outright.",
      "slogan": "Everyone gets the same AI. Your data is the only edge.",
      "knowsAbout": ["Data Vault 2.0", "Data warehousing", "dbt", "Snowflake", "BigQuery", "DuckDB", "Data governance", "Data lineage", "Schema contracts"],
      "areaServed": "Global",
      "foundingDate": "2018"
    })} />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="border-b border-rule bg-paper/85 backdrop-blur sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between gap-8">
        <a href="/" class="flex items-center gap-3">
          <img src="/logo-dark.svg" alt="Tecnofin" class="h-9 w-auto" height="36" />
        </a>
        <nav class="hidden md:flex items-center gap-9 text-[13px] font-medium">
          {nav.map((item) => (
            <a
              href={item.href}
              class={`relative transition-colors ${isActive(item.href) ? 'text-ink' : 'text-muted hover:text-ink'}`}
            >
              {item.label}
              {isActive(item.href) && (
                <span class="absolute -bottom-[26px] left-0 right-0 h-[2px] bg-oxblood"></span>
              )}
            </a>
          ))}
        </nav>
        <div class="flex items-center gap-3">
          <a href="/contact" class="btn-oxblood hidden md:inline-flex">
            Start a two-week build
            <span aria-hidden="true">→</span>
          </a>

          <!-- Mobile menu — pure-CSS disclosure, no JS -->
          <details class="mobile-nav md:hidden">
            <summary class="mobile-nav__toggle" aria-label="Toggle navigation menu">
              <svg class="mobile-nav__icon mobile-nav__icon--open" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="3" y1="6" x2="17" y2="6" /><line x1="3" y1="10" x2="17" y2="10" /><line x1="3" y1="14" x2="17" y2="14" />
              </svg>
              <svg class="mobile-nav__icon mobile-nav__icon--close" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <line x1="5" y1="5" x2="15" y2="15" /><line x1="15" y1="5" x2="5" y2="15" />
              </svg>
            </summary>
            <nav class="mobile-nav__panel">
              {nav.map((item) => (
                <a href={item.href} class={`mobile-nav__link ${isActive(item.href) ? 'is-active' : ''}`}>
                  {item.label}
                </a>
              ))}
              <a href="/contact" class="btn-oxblood mt-4 self-start">
                Start a two-week build
                <span aria-hidden="true">→</span>
              </a>
            </nav>
          </details>
        </div>
      </div>
    </header>

    <!-- Main Container -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-rule bg-paper-deep/40 mt-24">
      <!-- Sign-off line -->
      <div class="max-w-6xl mx-auto px-6 pt-20 pb-16">
        <p class="display text-4xl md:text-6xl text-ink max-w-4xl leading-[1.02]">
          Built for teams that treat data as <em class="italic text-oxblood">infrastructure</em>, not output.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="/contact" class="btn-oxblood">
            Start a two-week build
            <span aria-hidden="true">→</span>
          </a>
          <a href="mailto:hello@tecnofin.io" class="btn-ghost">hello@tecnofin.io</a>
        </div>
      </div>

      <!-- Structured columns -->
      <div class="border-t border-rule">
        <div class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-2 md:grid-cols-12 gap-8 text-sm">
          <div class="col-span-2 md:col-span-4">
            <img src="/logo-dark.svg" alt="Tecnofin" class="h-8 w-auto mb-4 opacity-90" height="32" />
            <p class="text-muted text-[13px] leading-relaxed max-w-xs">
              Pipeline infrastructure and Data Vault engineering for enterprise analytics teams.
            </p>
          </div>
          <div class="md:col-span-3">
            <p class="eyebrow mb-4">Capabilities</p>
            <ul class="flex flex-col gap-2 text-ink-soft">
              {expertiseLinks.map((link) => (
                <li>
                  <a href={link.href} class="hover:text-oxblood transition-colors">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
          <div class="md:col-span-3">
            <p class="eyebrow mb-4">Firm</p>
            <ul class="flex flex-col gap-2 text-ink-soft">
              <li><a href="/value" class="hover:text-oxblood transition-colors">Business Value</a></li>
              <li><a href="/dna" class="hover:text-oxblood transition-colors">How We Work</a></li>
              <li><a href="/success-cases" class="hover:text-oxblood transition-colors">Success Cases</a></li>
              <li><a href="/contact" class="hover:text-oxblood transition-colors">Contact</a></li>
            </ul>
          </div>
          <div class="md:col-span-2">
            <p class="eyebrow mb-4">Stack</p>
            <ul class="flex flex-col gap-2 text-ink-soft font-mono text-[12px]">
              <li>Snowflake</li>
              <li>BigQuery</li>
              <li>dbt · DuckDB</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Colophon -->
      <div class="border-t border-rule">
        <div class="max-w-6xl mx-auto px-6 py-6 flex flex-col md:flex-row items-start md:items-center justify-between gap-3 text-[11px] font-mono uppercase tracking-widest text-muted">
          <div>&copy; {new Date().getFullYear()} Tecnofin · All rights reserved</div>
          <div class="flex gap-6">
            <span>Made for engineering teams</span>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  /* Mobile disclosure menu — pure CSS, no JS. The header is sticky (a
     positioned ancestor), so the panel resolves its absolute position to it. */
  .mobile-nav { position: static; }

  .mobile-nav__toggle {
    list-style: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--color-rule);
    border-radius: 999px;
    color: var(--color-ink);
    cursor: pointer;
    transition: border-color 200ms ease, color 200ms ease;
  }
  .mobile-nav__toggle:hover { border-color: var(--color-oxblood); color: var(--color-oxblood); }
  .mobile-nav__toggle::-webkit-details-marker { display: none; }

  .mobile-nav__icon--close { display: none; }
  .mobile-nav[open] .mobile-nav__icon--open { display: none; }
  .mobile-nav[open] .mobile-nav__icon--close { display: inline; }

  .mobile-nav__panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    padding: 0.5rem 1.5rem 1.5rem;
    box-shadow: 0 24px 40px -24px rgba(0, 0, 0, 0.7);
  }
  .mobile-nav__link {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-ink-soft);
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-rule);
    transition: color 200ms ease;
  }
  .mobile-nav__link:hover { color: var(--color-oxblood); }
  .mobile-nav__link.is-active { color: var(--color-oxblood); }
</style>
