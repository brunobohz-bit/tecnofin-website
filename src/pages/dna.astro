---
import { getEntry, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRINCIPLES, PROCESS } from '../config/site';
import SchemaContract from '../components/diagrams/SchemaContract.astro';
import EngagementArc from '../components/diagrams/EngagementArc.astro';

const dnaContent = await getEntry('pages', 'dna');
if (!dnaContent) {
  throw new Error("Unable to locate dna.md in content layer.");
}
const { Content } = await render(dnaContent);
---

<BaseLayout title={dnaContent.data.title} description={dnaContent.data.description}>
  <!-- Header -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 pt-24 pb-20 grid grid-cols-1 md:grid-cols-12 gap-12 items-end">
      <div class="md:col-span-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="rule-oxblood"></span>
          <span class="eyebrow-oxblood">§ How we work</span>
        </div>
        <h1 class="display text-5xl md:text-7xl leading-[0.98]">
          {dnaContent.data.title}
        </h1>
      </div>
      <div class="md:col-span-4">
        <p class="font-mono text-[11px] uppercase tracking-widest text-muted">
          A short field manual <br/> for how we operate.
        </p>
      </div>
    </div>
  </section>

  <!-- Operating Principles — three columns (relocated from home) -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-3xl mb-16">
        <span class="eyebrow-oxblood">§ Operating principles</span>
        <h2 class="display text-3xl md:text-5xl mt-4 leading-[1.05]">
          Three rules we will not compromise on.
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-rule reveal-group">
        {PRINCIPLES.map((p) => (
          <article class="bg-paper p-8 md:p-10 flex flex-col gap-4 min-h-[260px]">
            <div class="index-number text-2xl">{p.index}</div>
            <h3 class="font-serif text-2xl leading-snug text-ink">{p.title}</h3>
            <p class="text-[17px] text-ink-soft leading-relaxed font-serif mt-auto">{p.body}</p>
          </article>
        ))}
      </div>

      <!-- Figure: schema-as-contract absorbs upstream drift -->
      <div class="mt-16 grid grid-cols-1 md:grid-cols-12 gap-10 items-center reveal">
        <div class="md:col-span-7">
          <SchemaContract />
        </div>
        <div class="md:col-span-5">
          <span class="eyebrow">Fig. 03 — Schema is contract</span>
          <p class="mt-4 font-serif text-ink-soft text-[1.25rem] leading-relaxed max-w-md">
            Sources drift. We absorb that drift at the contract layer, so the
            interface your downstream consumers depend on never breaks beneath them.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Structural beliefs — editorial body from dna.md -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-24 grid grid-cols-1 md:grid-cols-12 gap-12">
      <div class="md:col-span-4">
        <span class="eyebrow-oxblood">§ Structural beliefs</span>
        <h2 class="display text-3xl md:text-4xl mt-4 leading-[1.05]">
          What we refuse to do.
        </h2>
        <span class="rule-oxblood mt-6"></span>
      </div>
      <div class="md:col-span-8">
        <div class="prose-editorial
                    prose-p:first-of-type:first-letter:font-display
                    prose-p:first-of-type:first-letter:text-[3.75rem]
                    prose-p:first-of-type:first-letter:float-left
                    prose-p:first-of-type:first-letter:mr-3
                    prose-p:first-of-type:first-letter:leading-[0.85]
                    prose-p:first-of-type:first-letter:text-oxblood">
          <Content />
        </div>
      </div>
    </div>
  </section>

  <!-- Engagement process timeline -->
  <section class="border-b border-rule bg-paper-deep/30">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <div class="max-w-3xl mb-16">
        <span class="eyebrow-oxblood">§ How an engagement runs</span>
        <h2 class="display text-3xl md:text-5xl mt-4 leading-[1.05]">
          Proof first. Then production. Then it's yours.
        </h2>
      </div>
      <div class="mb-16 reveal">
        <EngagementArc />
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-rule reveal-group">
        {PROCESS.map((p) => (
          <article class="bg-paper p-8 md:p-10 flex flex-col gap-5 min-h-[280px]">
            <div class="flex items-baseline gap-3">
              <span class="index-number text-3xl">{p.step}</span>
              <span class="rule-oxblood"></span>
            </div>
            <h3 class="font-serif text-2xl leading-snug text-ink">{p.phase}</h3>
            <p class="text-[17px] text-ink-soft leading-relaxed font-serif mt-auto">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="border-b border-rule">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <p class="display text-4xl md:text-5xl text-ink max-w-3xl leading-[1.05]">
        The fastest way to see how we work is to watch us build.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a href="/contact" class="btn-oxblood">
          Start a two-week build
          <span aria-hidden="true">→</span>
        </a>
        <a href="/success-cases" class="btn-ghost">
          See the outcomes
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
